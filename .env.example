# Copier en .env puis ajuster :  cp .env.example .env

# Version applicative (sert au tag des images Docker en CI)
APP_VERSION=0.1.0

# Ports exposés sur l'hôte
FASTAPI_PORT=8080
STREAMLIT_PORT=8502
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
NODE_EXPORTER_PORT=9100
UPTIME_KUMA_PORT=3001

# Identifiants Grafana (à changer hors démo)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
